# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Groq API Key from https://console.groq.com
GROQ_API_KEY=

# OpenRouter API Key (optional, if using OpenRouter instead of Groq)
OPENROUTER_API_KEY=

# HTTP Proxy URL (optional, for accessing Groq from restricted regions)
# Format: http://user:password@host:port
PROXY_URL=

# OpenAI API Key (optional, fallback if using OpenAI directly)
OPENAI_API_KEY=

# Hugging Face Token for downloading sentence-transformers models
# Get it from https://huggingface.co/settings/tokens
HF_TOKEN=hf_
